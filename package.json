{
  "name": "manewax",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:api": "tsx server/local-api.ts",
    "build": "next build",
    "build:lambda": "esbuild server/lambda/handler.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist-lambda/handler.cjs",
    "package:lambda": "npm run build:lambda && cd dist-lambda && zip -q function.zip handler.cjs",
    "start": "next start",
    "lint": "eslint",
    "type-check": "node -e \"require('fs').rmSync('.next/dev/types', { recursive: true, force: true })\" && next typegen && tsc --noEmit",
    "env:use:sandbox": "bash scripts/env/use-env.sh sandbox",
    "env:use:production": "bash scripts/env/use-env.sh production",
    "docker:build": "docker build -t manewax:latest .",
    "docker:run": "bash scripts/docker/run.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx lib/db/seed.ts",
    "db:migrate:product-status": "tsx lib/db/migrate-product-status.ts",
    "stripe:promo:earlybird": "tsx scripts/stripe/bootstrap-earlybird-promo.ts",
    "aws:ecr-login": "bash scripts/aws/ecr-login.sh",
    "aws:deploy-ecs": "bash scripts/aws/deploy-ecs.sh",
    "aws:create-secrets": "bash scripts/aws/create-secrets.sh",
    "aws:create-secrets:sandbox": "bash scripts/aws/create-secrets.sh .env.sandbox manewax-sandbox",
    "aws:create-secrets:production": "bash scripts/aws/create-secrets.sh .env.production manewax",
    "aws:create-lambda-role": "bash scripts/aws/create-lambda-execution-role.sh",
    "aws:deploy-lambda-api": "bash scripts/aws/deploy-lambda-api.sh",
    "aws:deploy-static": "bash scripts/aws/deploy-static-site.sh"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.5",
    "@neondatabase/serverless": "^1.0.2",
    "@stripe/stripe-js": "^8.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^1.0.1",
    "next": "16.2.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/aws-lambda": "^8.10.152",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/stripe": "^8.0.416",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
