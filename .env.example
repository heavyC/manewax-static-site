# Public static-site runtime values (safe for S3-hosted frontend builds)
NEXT_PUBLIC_APP_URL="https://www.example.com"
NEXT_PUBLIC_API_BASE_URL="https://api.example.com/api"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key"

# Optional client-side promo fallback for static mode
NEXT_PUBLIC_FALLBACK_PROMO_CODE="EARLYBIRD_DISCOUNT"
NEXT_PUBLIC_FALLBACK_PROMO_TYPE="percentage"
NEXT_PUBLIC_FALLBACK_PROMO_VALUE="10"

# Optional build-time catalog source from Neon
# If omitted, the site falls back to the local mock product catalog during `next build`.
DATABASE_URL="your-neon-postgres-connection-string"

# Backend-only values (NOT for the S3 bucket itself)
# Use these when deploying the extracted `server/api` handlers to Lambda/API Gateway.
ALLOWED_ORIGIN="https://www.example.com"
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"
STRIPE_PROMO_EARLYBIRD_ID="promo_1TFPWoGxb4EX9yHrMVjod3vi"

# Optional Clerk values if you later re-enable auth on a separate backend/app layer
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="your-clerk-publishable-key"
CLERK_SECRET_KEY="your-clerk-secret-key"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"